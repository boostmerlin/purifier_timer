.page {
  padding: 24rpx;
}

.panel {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.panel-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-label {
  font-size: 25rpx;
  color: #6b7280;
}

.status-value {
  font-size: 25rpx;
  color: #111827;
  font-weight: 600;
}

.key-box {
  margin-top: 6rpx;
  border: 1px solid #d0d7de;
  border-radius: 12rpx;
  background: #f6f8fa;
  padding: 14rpx;
}

.key-label {
  display: block;
  font-size: 22rpx;
  color: #0969da;
  margin-bottom: 6rpx;
}

.key-value {
  font-size: 22rpx;
  color: #1f2937;
  word-break: break-all;
}

.action-group {
  margin-top: 8rpx;
  display: flex;
  gap: 10rpx;
}

.action-btn {
  width: 100%;
  min-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
  line-height: 72rpx;
}

.action-btn::after {
  border: none;
}

.desc {
  font-size: 25rpx;
  color: #6b7280;
  line-height: 1.6;
}

.divider {
  margin: 6rpx 0;
  border-top: 1px dashed #d0d7de;
}

.sub-title {
  font-size: 24rpx;
  color: #374151;
  font-weight: 600;
}

.key-input {
  height: 72rpx;
  border: 1px solid #d0d7de;
  border-radius: 12rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  background: #ffffff;
}
